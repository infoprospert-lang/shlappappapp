# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# WEBHOOK_URL: The n8n webhook URL for data export.
WEBHOOK_URL="https://n8n.srv1130396.hstgr.cloud/webhook/dd3205b3-9acd-43c5-8b62-5d19eafa6149"

# E-Mail: SMTP-Zugangsdaten für automatischen Versand nach Vorgangsabschluss.
# Alle Werte müssen serverseitig in der .env konfiguriert werden – nie in der App speichern.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
# SMTP_SECURE: "true" für Port 465 (SSL), leer lassen für STARTTLS (Port 587)
SMTP_SECURE=""
SMTP_USER="absender@example.com"
SMTP_PASS="dein-smtp-passwort"
# SMTP_FROM: Absender-Anzeigename + Adresse (optional, Standard: SMTP_USER)
SMTP_FROM="AppSchleppen <absender@example.com>"
# OFFICE_EMAIL: Empfänger-Adresse für Vorgangszusammenfassungen
OFFICE_EMAIL="buero@example.com"
